# ===================================================================
# Easy-Social V2 — Variáveis de ambiente (TEMPLATE)
# Copie para .env e preencha. NUNCA commite o .env real.
# ===================================================================

# --- API Backend ---
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT_MS=30000

# --- Autenticação ---
# Token JWT é guardado em httpOnly cookie pelo backend.
# Frontend só precisa saber o nome do cookie pra checagem CSRF.
VITE_AUTH_COOKIE_NAME=es_session
VITE_AUTH_CSRF_HEADER=X-CSRF-Token

# --- App ---
VITE_APP_NAME=Easy-Social
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=development

# --- Feature flags ---
VITE_FEATURE_DEBUG_PANEL=false
VITE_FEATURE_BRAIN_ANIMATIONS=true

# --- NUNCA colocar aqui ---
# - Senhas
# - Chaves privadas
# - Certificado A1
# - Tokens de produção
# Tudo isso fica no backend ou em secret manager.
