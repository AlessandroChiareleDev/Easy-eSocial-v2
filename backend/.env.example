# --- Postgres LOCAL (banco da empresa SOLUCOES) ---
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=easy_social_solucoes
LOCAL_DB_USER=easy_social_user
LOCAL_DB_PASSWORD=
LOCAL_DB_SSL=false

# --- Sistema DB (multi-tenant routing + auth) ---
# DSN completo: postgresql://user:pass@host:5432/easy_esocial_sistema
# Vazio = auth desabilitado (modo legado)
SISTEMA_DB_URL=

# --- Auth (JWT) ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# --- Fernet (encriptar senhas de cert A1) ---
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- API ---
API_HOST=127.0.0.1
API_PORT=8001
# CORS — front Vite roda em 5173
CORS_ORIGINS=http://localhost:5173

# --- Upload ---
# Limite por arquivo em bytes (3 GB)
MAX_UPLOAD_BYTES=3221225472
