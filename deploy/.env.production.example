# Easy eSocial V2 — exemplo de .env de produção (VPS)
# Copiar para /opt/easy-esocial/backend/.env  (chmod 600, owner esocial:esocial)
# Os nomes batem com backend/app/config.py.

# === DB sistema (Supabase) ===
SISTEMA_DB_URL=postgresql://postgres:SENHA_AQUI@db.kjbgiwnlvqnrfdozjvhq.supabase.co:5432/postgres?sslmode=require

# === Auth (JWT HS256) ===
# Gerar: openssl rand -hex 64
JWT_SECRET=TROCAR_POR_SEGREDO_LONGO_GERADO
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# === Cert A1 (Fernet) ===
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=TROCAR_POR_FERNET_KEY_BASE64

# === eSocial ===
ESOCIAL_AMBIENTE=producao
# producao | producao-restrita

# === API ===
API_HOST=127.0.0.1
API_PORT=8001

# === CORS ===
# Frontend é servido pelo mesmo origin (nginx). Se outro domínio acessar a API,
# listar com vírgula. Padrão dev: http://localhost:5173
CORS_ORIGINS=https://easyesocial.com.br

# === Upload ===
# 3 GB
MAX_UPLOAD_BYTES=3221225472
