# ===================================================================
# Easy-Social V2 — .gitignore BLINDADO
# Nunca remover entradas sem revisar (proteção anti-vazamento)
# ===================================================================

# --- SEGREDOS / CREDENCIAIS (NUNCA commitar) ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
*.cert
*.jks
*.keystore
secrets/
.secrets/
credentials.json
service-account*.json

# --- Certificado A1 eSocial ---
*.A1
*.a1
*A1*.pfx
*A1*.p12
certificados/
certificates/

# --- Node / npm / pnpm / yarn ---
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/install-state.gz
.pnpm-store/
.npm-debug.log*
.yarn-debug.log*
.yarn-error.log*

# --- Build outputs ---
dist/
dist-ssr/
build/
.output/
.nuxt/
.vite/
*.local

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# --- Test coverage ---
coverage/
.nyc_output/

# --- Temp ---
.cache/
.tmp/
tmp/
temp/
_tmp_*.py
*_tmp*.json
backend/_tmp_*.json
backend/_tmp_*.py
inspect_*.py
backend/search_cpf.py

# --- Bancos locais / artefatos operacionais ---
*.db
*.sqlite
*.sqlite3

# --- TypeScript build info ---
*.tsbuildinfo
